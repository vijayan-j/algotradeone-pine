//@version=6
// =============================================================================
//  AlgoTradeOneSignals — confluence leg primitives extracted from the
//  AlgoTradeOne Signal Engine. The four export bodies are byte-faithful to the
//  indicator's formulas so
//  a future backtest strategy twin can share ONE implementation of the legs.
//
//  IMPORTANT
//    The live indicator (indicators/algotradeone-signal-engine.pine) stays
//    self-contained on purpose — it must compile on TradingView without any
//    published dependency. This library is for the strategy twin, not the live
//    script. To use it you must publish it (even privately) on TradingView and
//    import by version:
//        import <your_tv_user>/AlgoTradeOneSignals/1 as ato
//    Every edit means republish + version bump + update the import. That friction
//    is why the legs are duplicated in the monolith rather than imported there.
// =============================================================================
library("AlgoTradeOneSignals", overlay = true)

// @function UT Bot ATR trailing stop (classic recursive stop).
// @param src      Source series (indicator uses close).
// @param keyValue ATR multiple / sensitivity (indicator default 2.0).
// @param atrLen   ATR period (1 = classic UT Bot, true-range driven).
// @returns [stop, bull, bear] where bull = src > stop.
export utBot(series float src, simple float keyValue, simple int atrLen) =>
    loss = keyValue * ta.atr(atrLen)
    var float stop = na
    stop := na(stop[1]) ? src :
       src > nz(stop[1]) and src[1] > nz(stop[1]) ? math.max(nz(stop[1]), src - loss) :
       src < nz(stop[1]) and src[1] < nz(stop[1]) ? math.min(nz(stop[1]), src + loss) :
       src > nz(stop[1]) ? src - loss : src + loss
    [stop, src > stop, src < stop]

// @function Supertrend direction leg.
// @param factor ATR multiplier / band distance (indicator default 2.0).
// @param atrLen ATR length (indicator default 10).
// @returns [line, bull, bear] — bull when ta.supertrend direction < 0.
export supertrend(simple float factor, simple int atrLen) =>
    [line, dir] = ta.supertrend(factor, atrLen)
    [line, dir < 0, dir > 0]

// @function Linear-regression value vs its smoothed signal line.
// @param src    Source series (indicator uses close).
// @param regLen Regression length (indicator default 11).
// @param sigLen Signal smoothing length (indicator default 7).
// @param useSma true = SMA signal, false = EMA signal.
// @returns [lrValue, signal, bull, bear].
export linRegCandle(series float src, simple int regLen, simple int sigLen, simple bool useSma) =>
    lrVal = ta.linreg(src, regLen, 0)
    sig   = useSma ? ta.sma(lrVal, sigLen) : ta.ema(lrVal, sigLen)
    [lrVal, sig, lrVal > sig, lrVal < sig]

// @function Anchored VWAP (manual cumulative; resets on the re-anchor trigger).
//   Polarity (price above/below = bull) is decided by the caller so mean-reversion
//   experiments stay out of the primitive. Compute `reanchor` in global scope:
//       atf = anchor == "Session" ? "D" : anchor == "Week" ? "W" : "M"
//       reanchor = ta.change(time(atf)) != 0
// @param reanchor true on the bar where accumulation restarts.
// @returns vwap value (hlc3 * volume weighted).
export anchoredVWAP(series bool reanchor) =>
    var float cumPV = na
    var float cumV  = na
    if reanchor or na(cumPV)
        cumPV := hlc3 * volume
        cumV  := volume
    else
        cumPV += hlc3 * volume
        cumV  += volume
    cumV > 0 ? cumPV / cumV : hlc3
